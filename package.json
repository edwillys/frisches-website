{
  "name": "frisches-website",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.14.1"
  },
  "scripts": {
    "dev": "npm run generate:gallery && vite",
    "host": "npm run generate:gallery && vite --host",
    "build": "npm run generate:gallery && run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "test:coverage": "vitest --coverage --run",
    "test:e2e": "playwright test",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "generate:gallery": "node scripts/generate-gallery.js",
    "normalize:svg": "node scripts/normalize-svg.js src/assets",
    "sync:r2:up": "node scripts/sync-r2.mjs up",
    "sync:r2:down": "node scripts/sync-r2.mjs down",
    "sync:r2:bisync": "node scripts/sync-r2.mjs bisync",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "@sentry/vue": "^10.49.0",
    "gsap": "^3.15.0",
    "pinia": "^3.0.3",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "sharp": "^0.34.5",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.18.11",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/eslint-plugin": "^1.6.16",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.9",
    "@vue/tsconfig": "^0.9.1",
    "canvas": "^3.2.3",
    "eslint": "^10.2.1",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-vue": "^10.9.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "jsdom": "^29.1.0",
    "lint-staged": "^16.2.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "3.6.2",
    "sass-embedded": "^1.99.0",
    "sql.js": "^1.14.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vite-imagetools": "^10.0.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7",
    "wrangler": "^4.86.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{css,scss}": [
      "prettier --write"
    ],
    "**/*.{md,json}": [
      "prettier --write"
    ]
  }
}
