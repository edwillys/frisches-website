{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start dev server",
      "type": "shell",
      "command": "npm",
      "args": ["run", "dev"],
      "isBackground": true,
      "group": "build",
      "problemMatcher": {
        "owner": "custom",
        "pattern": {
          "regexp": ".",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\s*>.*dev",
          "endsPattern": "Local:\\s+http://localhost:5173/?"
        }
      }
    },
    {
      "label": "Run unit tests",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:unit"],
      "group": "test"
    },
    {
      "label": "Run e2e tests",
      "type": "shell",
      "command": "npm",
      "args": ["run", "test:e2e"],
      "group": "test"
    },
    {
      "label": "Normalize SVG assets",
      "type": "shell",
      "command": "npm",
      "args": ["run", "normalize:svg"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
